<Window x:Class="WpfUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Online Library MVVM" Height="500" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="MenuButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#3F51B5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="Height" Value="38"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.ColumnSpan="2" Background="#263238">
            <TextBlock Text="Online Library MVVM"
                       Foreground="White"
                       FontSize="26"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"/>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Background="#ECEFF1">
            <StackPanel Margin="10">
                <Button Content="Додати"
                        Style="{StaticResource MenuButtonStyle}"
                        Command="{Binding AddCommand}"/>

                <Button Content="Редагувати"
                        Style="{StaticResource MenuButtonStyle}"
                        Command="{Binding EditCommand}"/>

                <Button Content="Видалити"
                        Style="{StaticResource MenuButtonStyle}"
                        Command="{Binding DeleteCommand}"/>

                <Button Content="Зберегти JSON"
                        Style="{StaticResource MenuButtonStyle}"
                        Command="{Binding SaveCommand}"/>

                <Button Content="Завантажити JSON"
                        Style="{StaticResource MenuButtonStyle}"
                        Command="{Binding LoadCommand}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Grid.Column="1" Margin="10">
            <DataGrid x:Name="BooksDataGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      ItemsSource="{Binding Books}"
                      SelectedItem="{Binding SelectedBook, Mode=TwoWay}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Назва" Binding="{Binding Title}" Width="*"/>
                    <DataGridTextColumn Header="Сторінки" Binding="{Binding Pages}" Width="100"/>
                    <DataGridTextColumn Header="Рейтинг" Binding="{Binding Rating}" Width="100"/>
                    <DataGridTextColumn Header="Категорія" Binding="{Binding Category}" Width="140"/>
                    <DataGridCheckBoxColumn Header="Доступна" Binding="{Binding IsAvailable}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>